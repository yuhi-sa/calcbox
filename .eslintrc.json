{
  "env": {
    "browser": true,
    "es6": false
  },
  "parserOptions": {
    "ecmaVersion": 5
  },
  "rules": {
    "no-undef": "warn",
    "no-unused-vars": "warn",
    "no-redeclare": "error",
    "eqeqeq": "warn",
    "no-eval": "error",
    "no-implied-eval": "error",
    "no-new-wrappers": "error",
    "no-with": "error",
    "semi": ["warn", "always"],
    "no-unreachable": "error",
    "no-dupe-keys": "error",
    "no-duplicate-case": "error",
    "valid-typeof": "error"
  },
  "globals": {
    "CalcBox": "readonly",
    "crypto": "readonly",
    "fetch": "readonly",
    "TextEncoder": "readonly",
    "TextDecoder": "readonly",
    "Uint8Array": "readonly",
    "Uint32Array": "readonly",
    "Promise": "readonly",
    "adsbygoogle": "writable"
  },
  "ignorePatterns": ["*.min.js", "sw.js"]
}
